# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase Service Role（サーバーサイドのみ・git に含めない）
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 本番の公開 URL（Vercel デプロイ後に設定）
NEXT_PUBLIC_APP_URL=https://shipfirst.vercel.app

# LemonSqueezy アフィリエイトコード
# https://app.lemonsqueezy.com → Affiliates → あなたのアフィリエイトコード
NEXT_PUBLIC_LS_AFFILIATE_CODE=your_affiliate_code

# オプション: npm run seed の対象メール
SEED_MAKER_EMAIL=maker-test@shipfirst.dev
