# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ローカル: seed / Stripe Webhook / オンボーディング状態の同期
# Vercel 本番: Webhook 用に必須（Dashboard のみに置く・git に含めない）
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 本番の公開 URL（Vercel デプロイ後に設定。プレビューだけなら未設定でも可）
NEXT_PUBLIC_APP_URL=https://shipfirst.vercel.app

# Stripe Connect（Week 2 Day 8+）
# Dashboard → Connect を有効化（Express）→ Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# イベント: account.updated（Day 8）、checkout.session.completed（Day 10）
STRIPE_WEBHOOK_SECRET=whsec_...

# App
PLATFORM_FEE_PERCENT=15

# オプション: npm run seed の対象メール
SEED_MAKER_EMAIL=maker-test@shipfirst.dev
